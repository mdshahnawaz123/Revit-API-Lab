<Window x:Class="RevitUI.UI.Interoperability.InteropDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B-Lab Interoperability Mission Control" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#1A1A1A" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="20" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#222" CornerRadius="20,0,0,20">
                <StackPanel Margin="20">
                    <TextBlock Text="B-LAB INTEROP" Foreground="#007ACC" FontSize="18" FontWeight="Bold" Margin="0,0,0,30"/>
                    
                    <TextBlock Text="DASHBOARD" Foreground="White" FontSize="12" Margin="0,0,0,15" Cursor="Hand"/>
                    <TextBlock Text="CLASSIFICATION" Foreground="Gray" FontSize="12" Margin="0,0,0,15" Cursor="Hand"/>
                    <TextBlock Text="IFC MANAGER" Foreground="Gray" FontSize="12" Margin="0,0,0,15" Cursor="Hand"/>
                    <TextBlock Text="COBIE EXTENSION" Foreground="Gray" FontSize="12" Margin="0,0,0,15" Cursor="Hand"/>
                    
                    <Separator Background="#444" Margin="0,20,0,20"/>
                    <Button x:Name="BtnRefresh" Content="REFRESH MODEL" Height="35" Background="#333" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Model Elements Coverage" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="Real-time interoperability and data health status" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <!-- Stats Grid -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ItemsCategory">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" Margin="0,0,0,10" Padding="15" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding CategoryName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                                            <ProgressBar Value="{Binding CoveragePercent}" Height="4" Margin="0,8,0,0" Foreground="#007ACC" Background="#111" BorderThickness="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                            <TextBlock Text="{Binding ElementCount}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding CoverageText}" Foreground="Gray" FontSize="10" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="EXPORT BCF" Width="120" Height="40" Background="Transparent" Foreground="Gray" BorderBrush="#444" Margin="0,0,10,0"/>
                    <Button Content="EXPORT COBIE" Width="120" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
