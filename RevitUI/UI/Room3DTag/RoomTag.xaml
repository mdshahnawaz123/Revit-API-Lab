<Window x:Class="RevitUI.UI.Room3DTag.RoomTag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:RevitUI.UI.Room3DTag"
        mc:Ignorable="d"
        Title="Engipedia 3D Room Tags"
        Height="400" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <!-- Base Button Style -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default Gray Button -->
        <Style x:Key="GrayButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <!-- Blue Button -->
        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Red/Danger Button -->
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="Foreground" Value="#C00000"/>
        </Style>

        <!-- Run Button -->
        <Style x:Key="RunButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <!-- Section Header TextBlock -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="StdCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="StdGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F7F7"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <!-- Spinner Button style (for +/-) -->
        <Style x:Key="SpinButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="46"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Bottom status bar -->
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  TITLE BAR                                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Tag icon approximation -->
                    <Border Width="30" Height="30" Background="#E8F0FE" CornerRadius="4"
                            BorderBrush="#90B4F5" BorderThickness="1" Margin="0,0,8,0">
                        <TextBlock Text="3D" FontWeight="Bold" FontSize="10"
                                   Foreground="#1A56C4"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="BIM Digital Design 3D Room Tags" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A1A1A" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT                                               -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,10,12,6">
            <Grid.ColumnDefinitions>
                <!-- Left/center content -->
                <ColumnDefinition Width="*"/>
                <!-- Right panel -->
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT + CENTER -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                <!-- ── Section: Specify what to create ───────────────── -->
                <TextBlock Text="Specify what to create" Style="{StaticResource SectionHeader}"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 -->
                    <CheckBox Grid.Row="0" Grid.Column="0" Content="Create 3D Room Tags"
                              IsChecked="True" VerticalAlignment="Center" FontSize="12"/>

                    <!-- Row 2: Phase combo -->
                    <ComboBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                              Style="{StaticResource StdCombo}" Width="200"
                              HorizontalAlignment="Left" Margin="0,2,0,2"
                              Name="PhaseComboBox">
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Place Elements in this Phase"
                               VerticalAlignment="Center" FontSize="11.5" Foreground="#444" Margin="8,0,0,0"/>

                    <!-- Row 3: Workset combo -->
                    <ComboBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                              Style="{StaticResource StdCombo}" Width="200"
                              HorizontalAlignment="Left" Margin="0,2,0,2"
                              Name="WorksetComboBox">
                    </ComboBox>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Place Elements in this Workset"
                               VerticalAlignment="Center" FontSize="11.5" Foreground="#444" Margin="8,0,0,0"/>
                </Grid>

                <Separator Background="#D0D0D0" Margin="0,2,0,10"/>

                <!-- ── Section: 3D Room Tag Options ──────────────────── -->
                <TextBlock Text="3D Room Tag Options" Style="{StaticResource SectionHeader}"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0" Grid.Column="0"
                              Style="{StaticResource StdCombo}" Width="280"
                              HorizontalAlignment="Left" Margin="0,0,8,0"
                              Name="RoomTagTypeComboBox">
                    </ComboBox>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Use this Generic Model Family &amp; Type"
                               VerticalAlignment="Center" FontSize="11.5" Foreground="#444"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Update existing 3D tag instances of the selected type while preserving their manual positions"
                              IsChecked="True" VerticalAlignment="Center" FontSize="11.5"/>
                </Grid>

                <Separator Background="#D0D0D0" Margin="0,4,0,10"/>

                

                <Separator Background="#D0D0D0" Margin="0,4,0,10"/>

            </StackPanel>

            <!-- RIGHT PANEL -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">

                <!-- Delete All Existing 3D Tags -->
                <Button Style="{StaticResource RedButton}"
                        HorizontalAlignment="Stretch" Margin="0,0,0,4"
                        Height="28"
                        Click="BtnDlt_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑 " FontSize="12"/>
                        <TextBlock Text="Delete All Existing 3D Tags" FontSize="11.5"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  BOTTOM STATUS BAR                                          -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#FAFAFA"
                BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="To run, select at least one checkbox or choose an item from the list"
                           FontSize="11" Foreground="#666" VerticalAlignment="Center"/>

                <Button Grid.Column="2" Style="{StaticResource GrayButton}"
                        Content="Close" Width="70" Margin="0,0,6,0"
                        Click="BtnClose_Click"/>

                <Button Grid.Column="3" Style="{StaticResource GrayButton}"
                        Content="Run" Width="70"
                        Click="BtnRun_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

