<Window x:Class="RevitUI.UI.Slope.SlopeAnalysisDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slope Analysis" Height="620" Width="380"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="HeaderColor" Color="#252526"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3E3E42"/>
        <SolidColorBrush x:Key="TextColor" Color="#E1E1E1"/>
        <SolidColorBrush x:Key="MutedText" Color="#999999"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0086EF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundColor}" CornerRadius="12" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderColor}" CornerRadius="12,12,0,0">
                <Grid Margin="20,0">
                    <TextBlock Text="SLOPE ANALYSIS" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="Gray" FontSize="18" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25">
                    <TextBlock Text="ANALYSIS TARGETS" Style="{StaticResource SectionHeader}"/>
                    <CheckBox x:Name="ChkFloors" Content="Include Floors" IsChecked="True"/>
                    <CheckBox x:Name="ChkRoofs" Content="Include Roofs" IsChecked="True"/>
                    <CheckBox x:Name="ChkTopo" Content="Include Topography" IsChecked="True"/>

                    <Border Height="1" Background="#333" Margin="0,10,0,25"/>

                    <TextBlock Text="VISUALIZATION" Style="{StaticResource SectionHeader}"/>
                    <RadioButton x:Name="RbNone" Content="Calculate Only (No Coloring)"/>
                    <RadioButton x:Name="RbHeatMap" Content="Apply Slope Heatmap" IsChecked="True"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,25">
                        <TextBlock Text="Angle Unit:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <ComboBox x:Name="ComboUnit" Width="140" Height="32" Background="#2D2D30" Foreground="White">
                            <ComboBoxItem Content="Degrees (°)" IsSelected="True"/>
                            <ComboBoxItem Content="Percentage (%)"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="COLOR THRESHOLDS" Style="{StaticResource SectionHeader}"/>
                    
                    <!-- Range 1 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Flat / Low Slope" Foreground="{StaticResource MutedText}" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtT1" Text="0" Background="#2D2D30" Foreground="White" BorderBrush="#444" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,15,0"/>
                        </StackPanel>
                        <Border x:Name="PickC1" Background="#90EE90" Style="{StaticResource ColorBox}" Grid.Column="1" VerticalAlignment="Bottom" MouseLeftButtonDown="ColorPicker_Click"/>
                    </Grid>

                    <!-- Range 2 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Medium Slope" Foreground="{StaticResource MutedText}" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtT2" Text="5" Background="#2D2D30" Foreground="White" BorderBrush="#444" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,15,0"/>
                        </StackPanel>
                        <Border x:Name="PickC2" Background="#FFA500" Style="{StaticResource ColorBox}" Grid.Column="1" VerticalAlignment="Bottom" MouseLeftButtonDown="ColorPicker_Click"/>
                    </Grid>

                    <!-- Range 3 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Steep Slope" Foreground="{StaticResource MutedText}" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtT3" Text="15" Background="#2D2D30" Foreground="White" BorderBrush="#444" Height="32" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,15,0"/>
                        </StackPanel>
                        <Border x:Name="PickC3" Background="#FF0000" Style="{StaticResource ColorBox}" Grid.Column="1" VerticalAlignment="Bottom" MouseLeftButtonDown="ColorPicker_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#252526" CornerRadius="0,0,12,12" Padding="25,15">
                <Button Content="START ANALYSIS" Style="{StaticResource ModernButton}" Click="BtnRun_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
