<Window x:Class="RevitUI.UI.ModelHealth.ModelHealthDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Digital Design - Model Health"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        Height="650" Width="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Border Background="#F9FAFB" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="White" CornerRadius="16,16,0,0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="25,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MODEL HEALTH" Foreground="#111827" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Performance metrics and QC summary" Foreground="#2563EB" FontSize="11" FontWeight="Medium" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#9CA3AF" BorderThickness="0" FontSize="20" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel>
                    <!-- SCORE SECTION -->
                    <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="110" Height="110">
                                <Ellipse Stroke="#F3F4F6" StrokeThickness="10"/>
                                <Ellipse x:Name="ScoreRing" Stroke="#10B981" StrokeThickness="10" StrokeDashArray="100" StrokeDashOffset="100"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="ScoreText" Text="--" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock Text="SCORE" FontSize="10" Foreground="#9CA3AF" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Margin="35,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="HealthStatus" Text="Scanning..." FontSize="20" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock Text="Overall Model Status" Foreground="#6B7280" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- METRICS GRID -->
                    <TextBlock Text="CRITICAL METRICS" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="5,0,0,12"/>
                    <UniformGrid Columns="2" Margin="0,0,0,20">
                        <Border Background="White" CornerRadius="10" Padding="15" Margin="5" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Warnings" Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                                <TextBlock x:Name="WarningCount" Text="0" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" Foreground="#111827"/>
                                <TextBlock Text="Active issues" Foreground="#9CA3AF" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="5" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="In-Place Families" Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                                <TextBlock x:Name="InPlaceCount" Text="0" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" Foreground="#EF4444"/>
                                <TextBlock Text="Performance load" Foreground="#9CA3AF" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="5" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="CAD Imports" Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                                <TextBlock x:Name="CadCount" Text="0" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" Foreground="#F59E0B"/>
                                <TextBlock Text="Linked DWGs" Foreground="#9CA3AF" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="10" Padding="15" Margin="5" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Redundant Rooms" Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                                <TextBlock x:Name="RoomCount" Text="0" FontSize="22" FontWeight="Bold" Margin="0,5,0,0" Foreground="#111827"/>
                                <TextBlock Text="Unplaced items" Foreground="#9CA3AF" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="SYSTEM STATS" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="5,10,0,12"/>
                    <Border Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10">
                        <UniformGrid Columns="2">
                            <StackPanel Margin="10,8">
                                <TextBlock Text="File Size" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="FileSizeText" Text="--" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="User Worksets" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="WorksetText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Design Options" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="DesignText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Raster Images" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="ImageText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Total Materials" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="MaterialText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Line Styles" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="StyleText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            
                            <!-- Hidden or compact metrics to satisfy code-behind -->
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Groups" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="GroupCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Links" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="LinkCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Orphaned Views" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="ViewCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Unused Filters" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="FilterCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Views w/o Templates" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="ViewTemplateText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                            <StackPanel Margin="10,8">
                                <TextBlock Text="Model Elements" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="TotalElementsText" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="#111827"/>
                            </StackPanel>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,16,16" Padding="25,20" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="RefreshBtn" Content="RE-SCAN MODEL" Background="#2563EB" Foreground="White" Height="48" Margin="0,0,10,0" FontWeight="Bold" FontSize="13" Click="Refresh_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>

                    <Button x:Name="ExportBtn" Grid.Column="1" Content="CSV" Background="#F3F4F6" Foreground="#111827" Height="48" Margin="0,0,10,0" FontWeight="Bold" FontSize="11" Click="Export_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>

                    <Button x:Name="ExportHtmlBtn" Grid.Column="2" Content="HTML" Background="#F3F4F6" Foreground="#10B981" Height="48" FontWeight="Bold" FontSize="11" Click="ExportHtml_Click">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
