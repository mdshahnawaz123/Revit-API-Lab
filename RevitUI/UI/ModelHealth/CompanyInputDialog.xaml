<Window x:Class="RevitUI.UI.ModelHealth.CompanyInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Settings" Height="180" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F9FAFB"
        Topmost="True">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Enter Company Name" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <TextBox x:Name="CompanyNameInput" Height="30" VerticalContentAlignment="Center" Padding="5"/>
            <Button Content="Generate Report" 
                    Margin="0,20,0,0" 
                    Height="35" 
                    Background="#2563EB" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="Generate_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
