<Window x:Class="RevitUI.UI.LoadingDigram.StructuralLoading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM Digital Design"
        Background="#F3F4F6"
        FontFamily="Segoe UI"
        FontSize="13"
        Height="700" Width="500"
        Icon="{x:Null}"
        KeyDown="Window_KeyDown" ResizeMode="NoResize">

    <DockPanel>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#E5E7EB"
                   Padding="6,2">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Foreground="#374151"/>
        </StatusBar>

        <!-- BUTTON BAR (STAYS FIXED) -->
        <Border DockPanel.Dock="Bottom"
                Background="White"
                Padding="10">

            <UniformGrid Columns="5">

                <Button Click="SyncRoom"
                        Background="#2563EB"
                        Foreground="White"
                        Margin="4"
                        Height="36">
                    Room Sync
                </Button>

                <Button Click="SyncWall"
                        Background="#2563EB"
                        Foreground="White"
                        Margin="4"
                        Height="36">
                    Wall Sync
                </Button>

                <Button Click="CreateFilled"
                        Background="#2563EB"
                        Foreground="White"
                        Margin="4"
                        Height="36">
                    Create Region
                </Button>

                <Button Click="CreateWallLine"
                        Background="#2563EB"
                        Foreground="White"
                        Margin="4"
                        Height="36">
                    Create Line
                </Button>

                <Button Click="CreateLegend"
                        Background="#10B981"
                        Foreground="White"
                        Margin="4"
                        Height="36">
                    Create Legend
                </Button>

            </UniformGrid>
        </Border>

        <!-- MAIN SCROLLABLE CONTENT -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="20">

                <!-- HEADER -->
                <TextBlock Text="Structural Loading Tools"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,15"/>

                <!-- ================= MODEL SOURCE ================= -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="Model Source"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">

                            <RadioButton x:Name="HostModelOption"
                                         Content="Host Model"
                                         IsChecked="True"
                                         GroupName="ModelSource"
                                         Margin="0,0,20,0"/>

                            <RadioButton x:Name="LinkedModelOption"
                                         Content="Linked Model"
                                         GroupName="ModelSource"/>

                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ================= ROOMS ================= -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="Rooms"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,10"/>

                        <!-- Scroll inside list -->
                        <ListBox x:Name="RoomListBox"
                                 Height="200"
                                 Background="#FAFAFA"
                                 BorderBrush="#E5E7EB">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                    </StackPanel>
                </Border>

                <!-- ================= WALLS ================= -->
                <Border Background="White"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="Walls"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,10"/>

                        <ListBox x:Name="WallListBox"
                                 Height="200"
                                 Background="#FAFAFA"
                                 BorderBrush="#E5E7EB">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
