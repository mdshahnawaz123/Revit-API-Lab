<Window x:Class="RevitUI.UI.SharedParam.SharedParamDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B-Lab Shared Parameter Manager" Height="600" Width="750"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#1A1A1A" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="15" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#222" CornerRadius="15,15,0,0" Padding="25,18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="SHARED PARAMETER MANAGER" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Bulk-apply shared parameters across categories" Foreground="#007ACC" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- File Loader -->
            <Border Grid.Row="1" Background="#1E1E1E" Padding="25,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFilePath" Grid.Column="0" Background="#111" Foreground="Gray" BorderBrush="#333" Padding="8,6" Text="Select a shared parameter file (.txt)..." VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="BROWSE" Width="80" Height="32" Background="#333" Foreground="White" BorderThickness="0" Margin="8,0,0,0" Click="BtnBrowse_Click" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="LOAD" Width="60" Height="32" Background="#007ACC" Foreground="White" BorderThickness="0" Margin="8,0,0,0" Click="BtnLoad_Click" Cursor="Hand" FontWeight="Bold"/>
                </Grid>
            </Border>

            <!-- Two-Panel Layout -->
            <Grid Grid.Row="2" Margin="25,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Parameters -->
                <Border Grid.Column="0" Background="#222" CornerRadius="10" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="PARAMETERS" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" x:Name="TxtSearchParam" Background="#111" Foreground="White" BorderBrush="#333" Padding="6,4" Margin="0,0,0,8" TextChanged="TxtSearchParam_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="#111"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ParamList"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Right: Categories -->
                <Border Grid.Column="2" Background="#222" CornerRadius="10" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TARGET CATEGORIES" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Select All" Click="BtnSelectAll_Click" Background="#333" Foreground="White" BorderThickness="0" Padding="8,3" Margin="0,0,5,0" Cursor="Hand"/>
                            <Button Content="Clear All" Click="BtnClearAll_Click" Background="#333" Foreground="White" BorderThickness="0" Padding="8,3" Cursor="Hand"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CategoryList"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Options Bar -->
            <Border Grid.Row="3" Background="#1E1E1E" Padding="25,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Binding:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RbInstance" Content="Instance" Foreground="White" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <RadioButton x:Name="RbType" Content="Type" Foreground="White" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    <TextBlock Text="Group:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbGroup" Width="180" Background="#111" Foreground="White" BorderBrush="#333"/>
                </StackPanel>
            </Border>

            <!-- Action Button -->
            <Border Grid.Row="4" Background="#222" CornerRadius="0,0,15,15" Padding="25,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="Gray" VerticalAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="1" Content="APPLY TO PROJECT" Width="180" Height="42" Background="#007ACC" Foreground="White" FontWeight="Bold" FontSize="13" Click="BtnApply_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
