<Window x:Class="RevitUI.UI.Dimensioning.DimensionDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BIM Digital Design - Dimension Automation" Height="380" Width="320"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#1A1A1A" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="12" BorderBrush="#333" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="DIMENSION AUTOMATION" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand"/>
                </Grid>
                <TextBlock Text="One-click precision dimensioning" Foreground="#007ACC" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Main Options -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Automation Mode" Foreground="Gray" FontSize="11" Margin="0,0,0,10"/>
                
                <!-- Mode Selection -->
                <RadioButton x:Name="RbGrids" IsChecked="True" GroupName="DimMode" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Grid to Grid" Foreground="White" FontSize="13"/>
                        <TextBlock Text=" (Parallel Grids)" Foreground="#555" FontSize="11" Margin="5,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbWalls" GroupName="DimMode" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Wall Openings" Foreground="White" FontSize="13"/>
                        <TextBlock Text=" (Doors/Windows)" Foreground="#555" FontSize="11" Margin="5,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbRooms" GroupName="DimMode" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Room Boundary" Foreground="White" FontSize="13"/>
                        <TextBlock Text=" (Center-to-Center)" Foreground="#555" FontSize="11" Margin="5,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RbMEP" GroupName="DimMode" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MEP Sleeves" Foreground="White" FontSize="13"/>
                        <TextBlock Text=" (Grid &amp; Column)" Foreground="#555" FontSize="11" Margin="5,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <Separator Background="#333" Margin="0,10,0,15"/>

                <TextBlock Text="Offset Distance" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtOffset" Text="1000" Background="#222" Foreground="White" BorderBrush="#444" Padding="5"/>
            </StackPanel>

            <!-- Action Button -->
            <Button Grid.Row="2" Content="RUN AUTOMATION" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold" Click="BtnRun_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
