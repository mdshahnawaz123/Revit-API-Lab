    <Border Background="#F9FAFB" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <Grid>
                    <TextBlock Text="DIMENSIONS" Foreground="#222" FontSize="20" FontWeight="Bold"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" Cursor="Hand" FontSize="18"/>
                </Grid>
                <Border Height="2" Background="#007ACC" Width="40" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                <TextBlock Text="Precision drafting assistant" Foreground="#888" FontSize="11" Margin="0,8,0,0" FontStyle="Italic"/>
            </StackPanel>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,12,0">
                    
                    <TextBlock Text="AUTOMATION MODE" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <RadioButton x:Name="RbGrids" IsChecked="True" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Grid to Grid" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Parallel)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbWalls" GroupName="DimMode" Margin="0,0,0,14" Checked="RbWalls_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Wall Openings" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Openings)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbWallsFull" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Wall Full" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Openings, Grids, Walls)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbRooms" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Room Boundary" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Area)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbMEP" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MEP Sleeves" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Coordination)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbColumns" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Grid to Column" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Structural)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="RbCurtainWalls" GroupName="DimMode" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Curtain Walls" Foreground="#333" FontSize="14" FontWeight="Medium" IsHitTestVisible="False"/>
                            <TextBlock Text=" (Mullions)" Foreground="#AAA" FontSize="10" Margin="6,3,0,0" IsHitTestVisible="False"/>
                        </StackPanel>
                    </RadioButton>

                    <Separator Background="#F0F0F0" Margin="0,10,0,20"/>

                    <TextBlock Text="PLACEMENT SETTINGS" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Dimension Style" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboDimStyle" Height="32" Background="White" BorderBrush="#DDD" Margin="0,0,0,18" FontSize="11"/>

                    <TextBlock Text="Offset Distance (mm)" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtOffset" Text="300" Height="32" Background="#FAFAFA" BorderBrush="#DDD" Padding="10,5" VerticalContentAlignment="Center" FontSize="11"/>

                    <Separator Background="#F0F0F0" Margin="0,20,0,20"/>
                    
                    <TextBlock Text="ADVANCED OPTIONS" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    <CheckBox x:Name="CbMultiTier" Content="Multi-Tier Grids (Overall)" Foreground="#444" IsChecked="True" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,5,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Dimension Ref:" Foreground="#444" FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <ComboBox x:Name="ComboDimRef" Grid.Column="1" Height="30" Background="White" BorderBrush="#DDD">
                            <ComboBoxItem Content="Faces" IsSelected="True"/>
                            <ComboBoxItem Content="Centerline"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="SCOPE &amp; SELECTION" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="RbIncludeHost" GroupName="ScopeMode" Content="Host" Foreground="#444" IsChecked="True" Margin="0,0,20,0"/>
                        <RadioButton x:Name="RbIncludeLinked" GroupName="ScopeMode" Content="Linked" Foreground="#444"/>
                    </StackPanel>
                    <RadioButton x:Name="RbSelectionOnly" GroupName="ScopeMode" Content="Selection Only" Foreground="#333" FontWeight="Bold" IsChecked="False" Margin="0,0,0,15"/>
                    <CheckBox x:Name="CbSameGroup" Content="Respect Groups" Foreground="#444" IsChecked="False" Margin="0,0,0,12"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Action Button -->
            <Button Grid.Row="2" Content="GENERATE DIMENSIONS" Height="55" Background="#007ACC" Foreground="White" FontSize="14" FontWeight="Bold" Click="BtnRun_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
