<Window x:Class="RevitUI.UI.LoginWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:local="clr-namespace:RevitUI.UI"
             Height="480" Width="400" ResizeMode="NoResize" 
             Title="BIM Digital Design" 
             Icon="{x:Null}">
    <Grid Margin="30">
        <!-- Login Panel -->
        <StackPanel x:Name="LoginPanel" Visibility="Visible">
            <TextBlock Text="BIM Digital Design" FontSize="24" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Sign in to your account" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#374151" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,15">
                <TextBox x:Name="TB_Username" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent"/>
            </Border>
            
            <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#374151" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,5">
                <Grid>
                    <PasswordBox x:Name="PB_Password" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" PasswordChanged="PB_Password_PasswordChanged"/>
                    <TextBox x:Name="TB_PasswordVisible" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" Visibility="Collapsed" TextChanged="TB_PasswordVisible_TextChanged"/>
                </Grid>
            </Border>
            <CheckBox x:Name="ChkShowPassword" Content="Show Password" Margin="0,0,0,10" Foreground="#6B7280" Click="ChkShowPassword_Click"/>
            
            <TextBlock x:Name="TB_Error" FontSize="12" Foreground="Red" TextWrapping="Wrap" MinHeight="18" Margin="0,0,0,10"/>
            
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="Cancel" Height="40" Background="White" Foreground="#374151" BorderBrush="#D1D5DB" BorderThickness="1" Click="Cancel_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                
                <Button Grid.Column="2" Content="Sign In" Height="40" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" IsDefault="True" Click="SignIn_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </Grid>

            <Button Content="Don't have access? Request here" Margin="0,5,0,0" Background="Transparent" BorderThickness="0" Foreground="#2563EB" Cursor="Hand" Click="RequestAccess_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value><ControlTemplate TargetType="Button"><ContentPresenter HorizontalAlignment="Center"/></ControlTemplate></Setter.Value>
                        </Setter>
                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="#1D4ED8"/></Trigger></Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Forgot Password? Click to Reset" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="#2563EB" Cursor="Hand" Click="ShowForgot_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value><ControlTemplate TargetType="Button"><ContentPresenter HorizontalAlignment="Center"/></ControlTemplate></Setter.Value>
                        </Setter>
                        <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="#1D4ED8"/></Trigger></Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Forgot Password Panel -->
        <StackPanel x:Name="ForgotPanel" Visibility="Collapsed">
            <TextBlock Text="Reset Password" FontSize="24" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Enter details to create a new password" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#374151" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,15">
                <TextBox x:Name="TB_ForgotUsername" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent"/>
            </Border>
            
            <TextBlock Text="Email Address" FontWeight="SemiBold" Foreground="#374151" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,15">
                <TextBox x:Name="TB_ForgotEmail" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent"/>
            </Border>

            <TextBlock Text="New Password" FontWeight="SemiBold" Foreground="#374151" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,5">
                <Grid>
                    <PasswordBox x:Name="PB_ForgotNewPassword" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" PasswordChanged="PB_ForgotNewPassword_PasswordChanged"/>
                    <TextBox x:Name="TB_ForgotNewPasswordVisible" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" Visibility="Collapsed" TextChanged="TB_ForgotNewPasswordVisible_TextChanged"/>
                </Grid>
            </Border>
            <CheckBox x:Name="ChkForgotShowPassword" Content="Show Password" Margin="0,0,0,10" Foreground="#6B7280" Click="ChkForgotShowPassword_Click"/>
            
            <TextBlock x:Name="TB_ForgotError" FontSize="12" Foreground="Red" TextWrapping="Wrap" MinHeight="18" Margin="0,0,0,10"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="Back to Login" Height="40" Background="White" Foreground="#374151" BorderBrush="#D1D5DB" BorderThickness="1" Click="BackToLogin_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
                
                <Button Grid.Column="2" Content="Reset Password" Height="40" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="ResetPassword_Click">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
