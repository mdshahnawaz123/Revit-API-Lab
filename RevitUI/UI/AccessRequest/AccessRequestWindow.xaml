<Window x:Class="RevitUI.UI.AccessRequest.AccessRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Request Access" Height="552" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB"
        ResizeMode="NoResize"
        Topmost="True"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Request Access" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,5" HorizontalAlignment="Center"/>
            <TextBlock Text="Fill in the details to request your license" FontSize="14" Foreground="#6B7280" Margin="0,0,0,25" HorizontalAlignment="Center"/>

            <!-- Form Fields -->
            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5">
                    <TextBox x:Name="TxtUsername" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent"/>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Email Address" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5">
                    <TextBox x:Name="TxtEmail" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent"/>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,15">
                <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="8,5">
                    <Grid>
                        <PasswordBox x:Name="TxtPassword" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" PasswordChanged="TxtPassword_PasswordChanged"/>
                        <TextBox x:Name="TxtPasswordVisible" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Background="Transparent" Visibility="Collapsed" TextChanged="TxtPasswordVisible_TextChanged"/>
                    </Grid>
                </Border>
                <CheckBox x:Name="ChkShowPassword" Content="Show Password" Margin="0,5,0,0" Foreground="#6B7280" Click="ChkShowPassword_Click"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Duration Required" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="2">
                    <ComboBox x:Name="ComboDuration" BorderThickness="0" Padding="10,5" FontSize="14" SelectionChanged="ComboDuration_SelectionChanged">
                        <ComboBoxItem Content="7 Days" IsSelected="True"/>
                        <ComboBoxItem Content="30 Days"/>
                        <ComboBoxItem Content="Lifetime"/>
                    </ComboBox>
                </Border>
            </StackPanel>

            <!-- Submit Button -->
            <Button x:Name="BtnSubmit" Content="Submit Request" Height="45" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="16" Click="BtnSubmit_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Cancel" Margin="0,10,0,0" Background="Transparent" Foreground="#6B7280" BorderThickness="0" Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#374151"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
