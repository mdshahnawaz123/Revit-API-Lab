<Window x:Class="RevitUI.UI.Purge.PurgeDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B-Lab Model Purge Plus" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="16" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="White" CornerRadius="16,16,0,0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="25,20">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="MODEL PURGE PLUS" Foreground="#111827" FontSize="18" FontWeight="Bold"/>
                        <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#9CA3AF" BorderThickness="0" Cursor="Hand" FontSize="18"/>
                    </Grid>
                    <TextBlock Text="Deep cleaning for professional models" Foreground="#2563EB" FontSize="11" FontWeight="Medium" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Cleaning Options -->
            <Border Grid.Row="1" Padding="30,25">
                <StackPanel>
                    <TextBlock Text="SELECT ITEMS TO PURGE" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <CheckBox x:Name="ChkTemplates" Content="Unused View Templates" Foreground="#111827" IsChecked="True" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkFilters" Content="Unused View Filters" Foreground="#111827" IsChecked="True" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkStyles" Content="Imported Line Styles (CAD junk)" Foreground="#111827" IsChecked="True" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkRooms" Content="Redundant/Not-Enclosed Rooms" Foreground="#111827" IsChecked="True" Margin="0,0,0,15"/>
                    <CheckBox x:Name="ChkViews" Content="Empty/Unplaced Views" Foreground="#111827" Margin="0,0,0,15"/>
                    
                    <Separator Background="#E5E7EB" Margin="0,10,0,20"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Warning: These actions cannot be undone." Foreground="#EF4444" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action Button -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,16,16" Padding="25,20" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <Button Content="START DEEP CLEAN" Height="48" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="13" Click="BtnPurge_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
