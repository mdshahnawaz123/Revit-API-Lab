<Window x:Class="RevitUI.UI.Purge.PurgeDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B-Lab Model Purge Plus" Height="450" Width="380"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#1A1A1A" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="15" BorderBrush="#333" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="MODEL PURGE PLUS" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand"/>
                </Grid>
                <TextBlock Text="Deep cleaning for professional models" Foreground="#007ACC" FontSize="11"/>
            </StackPanel>

            <!-- Cleaning Options -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Select Items to Purge" Foreground="Gray" FontSize="11" Margin="0,0,0,10"/>
                
                <CheckBox x:Name="ChkTemplates" Content="Unused View Templates" Foreground="White" IsChecked="True" Margin="0,0,0,12"/>
                <CheckBox x:Name="ChkFilters" Content="Unused View Filters" Foreground="White" IsChecked="True" Margin="0,0,0,12"/>
                <CheckBox x:Name="ChkStyles" Content="Imported Line Styles (CAD junk)" Foreground="White" IsChecked="True" Margin="0,0,0,12"/>
                <CheckBox x:Name="ChkRooms" Content="Redundant/Not-Enclosed Rooms" Foreground="White" IsChecked="True" Margin="0,0,0,12"/>
                <CheckBox x:Name="ChkViews" Content="Empty/Unplaced Views" Foreground="White" Margin="0,0,0,12"/>
                
                <Separator Background="#333" Margin="0,10,0,15"/>
                <TextBlock Text="Warning: These actions cannot be undone." Foreground="#FF4500" FontSize="10" FontStyle="Italic"/>
            </StackPanel>

            <!-- Action Button -->
            <Button Grid.Row="2" Content="START DEEP CLEAN" Height="45" Background="#007ACC" Foreground="White" FontWeight="Bold" Click="BtnPurge_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
