<Window x:Class="RevitUI.UI.RoomFinish.RoomFinishDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Finish Generator" Height="780" Width="480"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">
    
    <Border Background="#F9FAFB" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <Grid>
                    <TextBlock Text="ROOM FINISHES" Foreground="#222" FontSize="20" FontWeight="Bold"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" Cursor="Hand" FontSize="18"/>
                </Grid>
                <Border Height="2" Background="#007ACC" Width="40" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                <TextBlock Text="Automated floor &amp; wall interior finishes" Foreground="#888" FontSize="11" Margin="0,8,0,0" FontStyle="Italic"/>
            </StackPanel>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,12,0">

                    <!-- Floor Finish Options -->
                    <TextBlock Text="FLOOR FINISH" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    <CheckBox x:Name="CbCreateFloor" Content="Create Floor Finishes" Foreground="#333" FontWeight="Bold" IsChecked="True" Margin="0,0,0,10"/>
                    <TextBlock Text="Select Floor Type:" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboFloorType" Height="30" Background="White" BorderBrush="#DDD" Margin="0,0,0,20"/>

                    <Separator Background="#F0F0F0" Margin="0,5,0,20"/>

                    <!-- Wall Finish Options -->
                    <TextBlock Text="WALL FINISH (PAINT/PLASTER)" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    <CheckBox x:Name="CbCreateWall" Content="Create Wall Finishes" Foreground="#333" FontWeight="Bold" IsChecked="True" Margin="0,0,0,10"/>
                    <TextBlock Text="Select Wall Type:" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboWallType" Height="30" Background="White" BorderBrush="#DDD" Margin="0,0,0,15"/>

                    <TextBlock Text="Wall Height Logic:" Foreground="#555" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="CbFindCeilingHost" Content="Find Ceiling/Slab in Host Model" Foreground="#444" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="CbFindCeilingLinked" Content="Find Ceiling/Slab in Linked Models" Foreground="#444" IsChecked="True" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Manual Height Override (mm):" VerticalAlignment="Center" Foreground="#555" FontSize="12" Margin="0,0,10,0"/>
                        <TextBox x:Name="TxtHeightOverride" Grid.Column="1" Height="28" Background="#FFF" BorderBrush="#DDD" Padding="5,0" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Separator Background="#F0F0F0" Margin="0,5,0,20"/>

                    <!-- Scope Selection -->
                    <TextBlock Text="SCOPE &amp; SELECTION" Foreground="#007ACC" FontSize="11" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <RadioButton x:Name="RbScopeSelection" GroupName="ScopeMode" Content="Selected Rooms Only" Foreground="#333" IsChecked="True" Margin="0,0,0,10"/>
                    <RadioButton x:Name="RbScopeLevel" GroupName="ScopeMode" Content="Active Level" Foreground="#333" Margin="0,0,0,10"/>
                    <RadioButton x:Name="RbScopeHost" GroupName="ScopeMode" Content="Entire Host Model" Foreground="#333" Margin="0,0,0,10"/>
                    <RadioButton x:Name="RbScopeLinked" GroupName="ScopeMode" Content="Include Linked Models" Foreground="#333" Margin="0,0,0,20"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer Action Buttons -->
            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                <Button x:Name="BtnGenerate" Content="GENERATE NEW" Height="45" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="BtnGenerate_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnSync" Content="SYNC EXISTING FINISHES" Height="45" Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="BtnSync_Click" Margin="0,10,0,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
            
        </Grid>
    </Border>
</Window>
