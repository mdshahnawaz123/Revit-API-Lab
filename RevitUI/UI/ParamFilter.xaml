<Window x:Class="RevitUI.UI.ParamFilter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RevitUI.UI"
        Title="Parameter Filter"
        Height="550" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/B_Lab_RevitUI;component/UI/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Label style -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <!-- Secondary Button -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="Margin" Value="4,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- Danger Button -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Foreground" Value="#C0392B"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="Margin" Value="4,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Scroll protection -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Category -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- Scope -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- Filter -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- Color -->
                <RowDefinition Height="*"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- CATEGORY -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CategoryCombo"
                          SelectionChanged="ElementWhenCategoryChanged"
                          DisplayMemberPath="Name"
                          Height="32"/>
            </StackPanel>

            <!-- SCOPE -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="SCOPE" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <RadioButton x:Name="ScopeActiveView" Content="Active View (Both)" IsChecked="True" Margin="0,0,15,0"/>
                    <RadioButton x:Name="ScopeHost" Content="Host Model Only" Margin="0,0,15,0"/>
                    <RadioButton x:Name="ScopeLink" Content="Linked Models Only"/>
                </StackPanel>
            </StackPanel>

            <!-- FILTER RULE -->
            <Border Grid.Row="4"
                    Style="{StaticResource Card}"
                    Padding="12">

                <StackPanel>
                    <TextBlock Text="FILTER RULE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Parameter -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Parameter" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="ParameterCombo"
                                      DisplayMemberPath="Definition.Name"
                                      Height="32"/>
                        </StackPanel>

                        <!-- Operator -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Operator" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="RuleCombo" Height="32">
                                <ComboBoxItem Content="Equals"/>
                                <ComboBoxItem Content="Contains"/>
                                <ComboBoxItem Content="Begins With"/>
                                <ComboBoxItem Content="Ends With"/>
                                <ComboBoxItem Content="Greater Than"/>
                                <ComboBoxItem Content="Less Than"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Value -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Value" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="ValueBox"
                                     Height="32"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- COLOR SECTION -->
            <Border Grid.Row="6"
                    Style="{StaticResource Card}"
                    Padding="12">

                <StackPanel>

                    <TextBlock Text="COLOR"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Preview -->
                    <Border x:Name="ColorPreview"
                            Height="80"
                            Background="White"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,0,10"/>

                    <!-- HEX -->
                    <TextBlock x:Name="HexText"
                               Text="#FFFFFF"
                               Margin="0,0,0,10"
                               Foreground="Gray"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Pick"
                                Width="80"
                                Margin="0,0,10,0"
                                Click="PickColor_Click"/>

                        <Button Content="Set Color"
                                Width="80"
                                Margin="0,0,10,0"
                                Click="AssignColor_Click"/>

                        <Button Content="Clear"
                                Width="80"
                                Click="ClearOverride_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ACTION BUTTONS -->
            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Isolate"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnIsolate"/>

                <Button Content="Clear"
                        Style="{StaticResource DangerButton}"
                        Click="OnClear"/>

                <Button Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        Click="OnClose"/>

                <Button Content="Find Elements"
                        Style="{StaticResource IconButton}"
                        Click="OnApplyFilter"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Window>
