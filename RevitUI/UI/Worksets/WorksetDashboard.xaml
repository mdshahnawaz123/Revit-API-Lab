<Window x:Class="RevitUI.UI.Worksets.WorksetDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="B-Lab Smart Workset Automator" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#1A1A1A" AllowsTransparency="True" WindowStyle="None">
    
    <Border CornerRadius="15" BorderBrush="#333" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="WORKSET AUTOMATOR" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="Gray" BorderThickness="0" Cursor="Hand"/>
                </Grid>
                <TextBlock Text="Map Categories to Project Worksets" Foreground="#007ACC" FontSize="11"/>
            </StackPanel>

            <!-- Mapping Table -->
            <DataGrid Grid.Row="1" x:Name="DgMapping" Background="Transparent" BorderThickness="0" 
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      RowBackground="#222" Foreground="White" GridLinesVisibility="None"
                      HeadersVisibility="Column" RowHeight="35">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#333"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CATEGORY" Binding="{Binding CategoryName}" Width="*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="TARGET WORKSET" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WorksetList}"
                                          SelectedItem="{Binding TargetWorkset, UpdateSourceTrigger=PropertyChanged}"
                                          Background="#111" Foreground="White" BorderThickness="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action Button -->
            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                <Button Content="APPLY TO MODEL" Height="45" Background="#007ACC" Foreground="White" FontWeight="Bold" Click="BtnApply_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
