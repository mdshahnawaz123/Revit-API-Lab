<Window x:Class="RevitUI.UI.Worksets.WorksetDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workset Pro" Height="620" Width="850"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <!-- Modern Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="HeaderColor" Color="#252526"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3E3E42"/>
        <SolidColorBrush x:Key="TextColor" Color="#E1E1E1"/>
        <SolidColorBrush x:Key="MutedText" Color="#999999"/>

        <!-- Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0086EF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundColor}" CornerRadius="12" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderColor}" CornerRadius="12,12,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WORKSET" Foreground="{StaticResource PrimaryColor}" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text=" POLICE" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Foreground="#888" FontSize="18" Cursor="Hand"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Configuration -->
                <StackPanel Grid.Column="0" Margin="0,0,25,0">
                    <TextBlock Text="FILTER SETTINGS" Foreground="{StaticResource MutedText}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15" />
                    
                    <TextBlock Text="Category" Foreground="{StaticResource TextColor}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbCategory" ItemsSource="{Binding Categories}" SelectionChanged="CbCategory_SelectionChanged"/>

                    <TextBlock Text="Element Type" Foreground="{StaticResource TextColor}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbElementType" ItemsSource="{Binding ElementTypes}" SelectionChanged="CbElementType_SelectionChanged"/>

                    <CheckBox x:Name="ChkAssignAll" Content="Apply to all types in category" IsChecked="{Binding AssignToAll}"/>

                    <Border Height="1" Background="#333" Margin="0,10,0,20"/>

                    <TextBlock Text="TARGET WORKSET" Foreground="{StaticResource MutedText}" FontSize="11" FontWeight="Bold" Margin="0,0,0,15" />
                    <ComboBox x:Name="CbWorkset" ItemsSource="{Binding Worksets}" SelectedItem="{Binding SelectedWorkset}"/>

                    <Button Content="Assign Selection" Style="{StaticResource ModernButton}" Height="45" Margin="0,5,0,10" Click="BtnAssign_Click"/>
                    <Button Content="Export Report" Style="{StaticResource SecondaryButton}" Height="35" Click="BtnExport_Click"/>
                </StackPanel>

                <!-- Right Panel: Element Inspection -->
                <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#2D2D30" CornerRadius="6,6,0,0" Padding="15,10">
                            <TextBlock Text="AFFECTED ELEMENTS" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" />
                        </Border>

                        <DataGrid Grid.Row="1" x:Name="DgElements" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  Background="Transparent" BorderThickness="0" GridLinesVisibility="None" 
                                  HeadersVisibility="Column" RowHeight="32" Foreground="White"
                                  RowBackground="Transparent" AlternatingRowBackground="#2D2D30">
                            
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.Resources>
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D2D30"/>
                                    <Setter Property="Foreground" Value="#AAA"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ELEMENT ID" Binding="{Binding Id}" Width="120"/>
                                <DataGridTextColumn Header="TYPE NAME" Binding="{Binding TypeName}" Width="*"/>
                                <DataGridTextColumn Header="CURRENT WORKSET" Binding="{Binding WorksetName}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
