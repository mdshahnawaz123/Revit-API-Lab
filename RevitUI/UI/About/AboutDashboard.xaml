<Window x:Class="RevitUI.UI.About.AboutDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About B-Lab Suite" Height="480" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="White"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- LICENSE STATUS -->
            <Border x:Name="LicenseBorder" Background="#DCFCE7" Padding="12,4" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#16A34A" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtLicenseStatus" Text="PRO ENTERPRISE LICENSE ACTIVE" Foreground="#16A34A" FontSize="9" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="TxtDaysRemaining" Text="Trial: 30 Days Remaining" Foreground="#6B7280" FontSize="11" Margin="0,-10,0,15" HorizontalAlignment="Center" Visibility="Collapsed"/>

            <!-- HEADER -->
            <TextBlock Text="B-Lab Revit Suite" FontSize="22" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Text="Version 1.0.2.0" Foreground="#6B7280" Margin="0,5,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Developed by BIM Digital Design" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center"/>
            <TextBlock Text="Advanced BIM Automation &amp; Intelligence" Foreground="#9CA3AF" FontSize="11" Margin="0,2,0,20" HorizontalAlignment="Center"/>

            <!-- CONTACT SECTION -->
            <Border Background="#F3F4F6" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="CONTACT SUPPORT" FontSize="10" FontWeight="Bold" Foreground="#6B7280" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock Text="📧" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold">
                            <Hyperlink NavigateUri="mailto:bimdigitaldesign@gmail.com" RequestNavigate="Email_RequestNavigate" Foreground="#2563EB" TextDecorations="None">
                                bimdigitaldesign@gmail.com
                                <Hyperlink.ToolTip>
                                    <ToolTip Content="Click to send email / Right-click to copy"/>
                                </Hyperlink.ToolTip>
                                <Hyperlink.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy Email" Click="CopyEmail_Click"/>
                                    </ContextMenu>
                                </Hyperlink.ContextMenu>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="📞" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+971 558570571" Foreground="#111827" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ACTIONS -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button x:Name="BtnRequestAccess" Content="Request Access" Width="110" Height="35" Margin="0,0,8,0" Click="RequestAccess_Click" Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Content="Website" Width="75" Height="35" Margin="0,0,8,0" Click="Support_Click" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Content="LinkedIn" Width="75" Height="35" Margin="0,0,8,0" Click="LinkedIn_Click" Background="#0077B5" Foreground="White" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
                <Button Content="Close" Width="60" Height="35" Click="Close_Click" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- SYSTEM INFO FOOTER -->
            <Separator Background="#F3F4F6" Margin="0,0,0,10"/>
            <TextBlock x:Name="TxtSystemInfo" Text="Revit Version | Assembly Version" Foreground="#9CA3AF" FontSize="9" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
