<Window x:Class="RevitUI.UI.RoomSheet.RoomSheetDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Sheet Creator" Height="650" Width="450"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="HeaderColor" Color="#252526"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3E3E42"/>
        <SolidColorBrush x:Key="TextColor" Color="#E1E1E1"/>
        <SolidColorBrush x:Key="MutedText" Color="#999999"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0086EF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundColor}" CornerRadius="12" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="85"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderColor}" CornerRadius="12,12,0,0">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ROOM SHEET" Foreground="{StaticResource PrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" CREATOR" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="Gray" FontSize="18" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="25,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Scope Selection -->
                        <TextBlock Text="SEARCH SCOPE" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" LetterSpacing="1"/>
                        <ComboBox x:Name="ComboScope" SelectionChanged="ComboScope_SelectionChanged">
                            <ComboBoxItem Content="Active View" IsSelected="True"/>
                            <ComboBoxItem Content="All Model"/>
                            <ComboBoxItem Content="Include Linked Models"/>
                        </ComboBox>

                        <!-- Room List -->
                        <TextBlock Text="SELECT ROOMS" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" LetterSpacing="1"/>
                        <TextBox x:Name="TxtSearchRoom" TextChanged="SearchRoom_TextChanged" ToolTip="Search by Name or Number..."/>
                        
                        <Grid Margin="0,0,0,5">
                            <CheckBox x:Name="ChkSelectAll" Content="Select All Rooms" Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Checked" FontSize="11"/>
                        </Grid>

                        <Border Background="#252526" CornerRadius="6" BorderBrush="#333" BorderThickness="1" Height="180">
                            <ListBox x:Name="ListRooms" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="5,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Number}" Foreground="{StaticResource PrimaryColor}" FontWeight="Bold" Width="50"/>
                                                <TextBlock Text="{Binding Name}" Foreground="White"/>
                                                <TextBlock Text="{Binding LevelName, StringFormat=' ({0})'}" Foreground="{StaticResource MutedText}" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                <TextBlock Text=" [LINKED]" Foreground="#F59E0B" FontSize="9" FontWeight="Bold" Margin="10,0,0,0" 
                                                           Visibility="{Binding LinkedIndicatorVisibility}"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Separator Background="#333" Margin="0,20"/>

                        <!-- Batch Settings -->
                        <TextBlock Text="SHEET SETTINGS" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="0,0,0,15" LetterSpacing="1"/>
                        
                        <TextBlock Text="Titleblock" Foreground="{StaticResource TextColor}" FontSize="11" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ComboTitleblock" DisplayMemberPath="Name"/>

                        <UniformGrid Columns="2" Margin="0,10,0,15">
                            <CheckBox x:Name="ChkAllElevations" Content="4 Elevations" IsChecked="True"/>
                            <CheckBox x:Name="Chk3DView" Content="3D Room View" IsChecked="True"/>
                        </UniformGrid>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Scale: " VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="ComboScale" Width="120" SelectedIndex="3">
                                <ComboBoxItem Content="1:10"/>
                                <ComboBoxItem Content="1:20"/>
                                <ComboBoxItem Content="1:25"/>
                                <ComboBoxItem Content="1:50"/>
                                <ComboBoxItem Content="1:100"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#252526" CornerRadius="0,0,12,12" Padding="25,15">
                <Button Content="BATCH CREATE SHEETS" Style="{StaticResource ModernButton}" Click="Create_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
