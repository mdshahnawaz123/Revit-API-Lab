<Window x:Class="RevitUI.UI.RoomSheet.RoomSheetDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Sheet Creator" Height="700" Width="480"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Professional Light Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#2563EB"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="HeaderColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextColor" Color="#111827"/>
        <SolidColorBrush x:Key="MutedText" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" BorderBrush="#D1D5DB" Background="White" Grid.Column="2" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                <Path Name="Arrow" Grid.Column="1" Fill="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="0,0,6,6"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True"><StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" /></ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,5,0,18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundColor}" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderColor}" CornerRadius="16,16,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ROOM SHEET" Foreground="{StaticResource PrimaryColor}" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text=" CREATOR" Foreground="{StaticResource TextColor}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#9CA3AF" FontSize="20" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="30,25">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Scope Selection -->
                        <TextBlock Text="SEARCH SCOPE" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="2,0,0,8"/>
                        <ComboBox x:Name="ComboScope" SelectionChanged="ComboScope_SelectionChanged">
                            <ComboBoxItem Content="Active View" IsSelected="True"/>
                            <ComboBoxItem Content="All Model"/>
                            <ComboBoxItem Content="Include Linked Models"/>
                        </ComboBox>

                        <!-- Room List -->
                        <TextBlock Text="SELECT ROOMS" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="2,10,0,8"/>
                        <TextBox x:Name="TxtSearchRoom" TextChanged="SearchRoom_TextChanged" Tag="Search by Name or Number..."/>
                        
                        <CheckBox x:Name="ChkSelectAll" Content="Select All Rooms" Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Checked" FontSize="12" Margin="5,0,0,12" FontWeight="SemiBold"/>

                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Height="220" Padding="5">
                            <ListBox x:Name="ListRooms" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="10,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Number}" Foreground="{StaticResource PrimaryColor}" FontWeight="Bold" Width="60"/>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextColor}"/>
                                                <TextBlock Text="{Binding LevelName, StringFormat=' ({0})'}" Foreground="{StaticResource MutedText}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                <TextBlock Text="LINKED" Foreground="#F59E0B" FontSize="9" FontWeight="Bold" Margin="10,0,0,0" 
                                                           Padding="4,1" Background="#FFFBEB" Visibility="{Binding LinkedIndicatorVisibility}"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,25,0,25"/>

                        <!-- Batch Settings -->
                        <TextBlock Text="SHEET SETTINGS" Foreground="{StaticResource MutedText}" FontSize="10" FontWeight="Bold" Margin="2,0,0,15"/>
                        
                        <TextBlock Text="Titleblock" Foreground="{StaticResource TextColor}" FontSize="12" FontWeight="SemiBold" Margin="2,0,0,6"/>
                        <ComboBox x:Name="ComboTitleblock" DisplayMemberPath="Name"/>

                        <UniformGrid Columns="2" Margin="5,10,0,15">
                            <CheckBox x:Name="ChkAllElevations" Content="4 Elevations" IsChecked="True"/>
                            <CheckBox x:Name="Chk3DView" Content="3D Room View" IsChecked="True"/>
                        </UniformGrid>

                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="Scale: " VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                            <ComboBox x:Name="ComboScale" Width="140" SelectedIndex="3">
                                <ComboBoxItem Content="1:10"/><ComboBoxItem Content="1:20"/><ComboBoxItem Content="1:25"/><ComboBoxItem Content="1:50"/><ComboBoxItem Content="1:100"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,16,16" Padding="30,20" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                <Button Content="BATCH CREATE SHEETS" Style="{StaticResource ModernButton}" Height="54" Click="Create_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
