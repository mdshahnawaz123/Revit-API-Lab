<Window x:Class="RevitUI.UI.DoorOpening"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RevitUI.UI"
        Height="450" Width="500"
        Title="BIM Digital Design"
        Icon="/DataLab;component/Resources/Door.png"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- Resources -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Layout -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1E1E1E">
            <TextBlock HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="MASTER DOOR AND WINDOW OPENING"/>
        </Border>

        <!-- CONTROLS -->
        <Border Grid.Row="1" Background="Honeydew" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="DoorCheckBox"
                              Content="Door"
                              Margin="10,0,0,0"
                              FontSize="14"
                              FontWeight="Bold"
                              IsChecked="True"/>

                    <CheckBox x:Name="WindowCheckBox"
                              Content="Window"
                              Margin="20,0,0,0"
                              FontSize="14"
                              FontWeight="Bold"
                              IsChecked="True"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="Scan Door"
                            Click="ScanBtn_Click"
                            Height="35"
                            Width="150"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"/>
                    
                    <Button Content="Create Openings"
                            Click="OpeningBtn"
                            Height="35"
                            Width="150"
                            Margin="20,0,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DATA GRID -->
        <DataGrid x:Name="OpeningDataGrid" 
                  Grid.Row="2" 
                  Margin="10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Level" Binding="{Binding ElementLevel}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Family Type" Binding="{Binding ElementType}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Link Source" Binding="{Binding LinkSource}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="#F3F3F3">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtStatus" Text="Ready" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                <TextBlock Text="Openings will be created in host model"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="Gray"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
